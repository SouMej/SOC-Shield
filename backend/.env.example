# SOC Platform Backend Configuration
# Copy this to .env and fill in your values

# Elasticsearch
ES_HOST=localhost
ES_PORT=9200

# AI Engine — Grok (xAI)
# Get your key at https://accounts.x.ai/
XAI_API_KEY=your-xai-api-key-here
AI_MODEL=grok-3-latest
AI_POLL_INTERVAL=10

# Log Simulator (set to false if using real Winlogbeat)
SIMULATOR_ENABLED=true
SIMULATOR_INTERVAL=2.0

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
